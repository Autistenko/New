#include <iostream>
#include <iomanip>
#include <locale>
#include <windows.h>
using namespace std;

int main() {

    SetConsoleOutputCP(CP_UTF8);
    SetConsoleCP(CP_UTF8);
    setlocale(LC_ALL, "English");

    cout << "Multiplication table:" << endl;
    cout << endl;

    cout << "   ";
    for (int i = 1; i <= 9; i++) {
        cout << setw(4) << i;
    }
    cout << endl;

    for (int i = 1; i <= 9; i++) {
        cout << setw(2) << i << " ";
        for (int j = 1; j <= 9; j++) {
            int result = i * j;
            cout << setw(4) << result;
        }
        cout << endl;
    }

    cout << endl;
    cout << "|_______________________________________|" << endl;
    cout << endl;

    int number;
    char choice;

    do {
        cout << "Enter the number for searching of the divisors: ";
        cin >> number;

        if (number <= 0) {
            cout << "Enter positive number" << endl;
            continue;
        }

        cout << "Divisors of the number " << number << ": ";

        for (int i = 1; i <= number; i++) {
            if (number % i == 0) {
                cout << i << " ";
            }
        }
        cout << endl;

        cout << "Need to find divisors of the other number? (y/n): ";
        cin >> choice;

    } while (choice == 'y' || choice == 'Y');

    cout << "Programm is complete, farewell!" << endl;

    return 0;
}
