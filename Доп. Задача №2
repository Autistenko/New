    cout << "\n/=== Задача 2 ===" << endl;

    double task2[31];
    int count2 = 0;

    if (N > 0) {
        task2[count2] = temperatures[0];
        count2++;

        for (int i = 1; i < N; i++) {
            if (temperatures[i] != temperatures[i - 1]) {
                task2[count2] = temperatures[i];
                count2++;
            }
        }
    }
    cout << "Массив после удаления одинаковых подряд идущих: ";
    if (count2 == 0) {
        cout << "массив пуст";
    }
    else {
        for (int i = 0; i < count2; i++) {
            cout << task2[i] << " ";
        }
    }
    cout << endl;
    return 0;
}
