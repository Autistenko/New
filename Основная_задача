#include <iostream>
#include <numeric>
#include<windows.h>
#include<cmath>
using namespace std;
int main() {
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);
    setlocale(LC_ALL, "Russian");
    int N;
    double temperatures[31];

    cout << "Введите количество дней от 1 до 31: ";
    cin >> N;
    while (N < 1 || N > 31) {
        cout << "Можно вводить только числа от 1 до 31: ";
        cin >> N;
    }
    cout << "значения температуры для каждого дня:\n";
    for (int i = 0; i < N; i++) {
        cout << "День " << i + 1 << ": ";
        cin >> temperatures[i];
    }
    cout << "\nТемпературы за месяц: ";
    for (int i = 0; i < N; i++) {
        cout << temperatures[i] << " ";
    }
    cout << endl;
    double maxTemp = temperatures[0];
    double minTemp = temperatures[0];

    for (int i = 1; i < N; i++) {
        if (temperatures[i] > maxTemp) maxTemp = temperatures[i];
        if (temperatures[i] < minTemp) minTemp = temperatures[i];
    }
    cout << "Самая маскимаоьна температура: " << maxTemp << endl;
    cout << "Самая минимальная температура: " << minTemp << endl;

    double sum = 0;
    for (int i = 0; i < N; i++) {
        sum += temperatures[i];
    }
    double average = sum / N;
    cout << "Среднемесячная температура: " << average << endl;

    int belowZero = 0;
    for (int i = 0; i < N; i++) {
        if (temperatures[i] < 0) belowZero++;
    }
    cout << "Дни с температурой ниже нуля: " << belowZero << endl;
}


